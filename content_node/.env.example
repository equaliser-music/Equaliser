# Equaliser Content Node — Environment Variables
# Copy to .env and change values for production.
# Variables marked [compose] have defaults set directly in docker-compose.yml;
# override them here or in a compose override file.

# ── Database (PostgreSQL, owned by the Equaliser relay) ─────────────────────
POSTGRES_USER=equaliser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=equaliser

# ── Public identity of this node ─────────────────────────────────────────────
# Absolute base URL used in NOSTR events (Blossom cover-art URLs etc.) so
# other nodes can reach this node's content. Leave empty for local dev.
# PUBLIC_BASE_URL=https://your-node.example.com

# CORS allowed origins (comma-separated). Set to your real domain(s) in prod.
# ALLOWED_ORIGINS=https://your-node.example.com

# ── Federation ───────────────────────────────────────────────────────────────
# Standard NOSTR relays for syncing registered users' social data
# (comma-separated). Must match between relay and orchestrator (both read it).
# STANDARD_RELAYS=wss://relay1.equaliser.app,wss://relay2.equaliser.app

# Peer Equaliser node relays for music-metadata sync (comma-separated). [compose]
# PEER_RELAYS=wss://peer-node.example.com/relay

# Event acceptance policy: equaliser_only | open | hybrid. [compose]
# EVENT_POLICY=equaliser_only

# Seconds between periodic full peer resyncs.
# [compose currently sets 60 — a TESTING value; use 3600 in production]
# SYNC_INTERVAL=3600

# ── Relay tuning (read by the Go relay; defaults in internal/config/config.go) ─
# RELAY_NAME=Equaliser Content Node Relay
# RELAY_DESCRIPTION=A NOSTR relay for the Equaliser music platform content node
# USER_FEED_DAYS=30
# USER_FEED_LIMIT=500
# MAX_SUBSCRIPTIONS=20
# MAX_FILTERS=10
# MAX_MESSAGE_LENGTH=65536
# MAX_EVENT_TAGS=2000

# ── Operators & admin ────────────────────────────────────────────────────────
# Bootstrap operator pubkeys (hex, comma-separated). Normally unnecessary:
# the first-run setup-token flow (/admin/setup.html) claims the first operator.
# OPERATOR_PUBKEYS=

# SECURITY: legacy admin backdoor for operator endpoints via the X-Admin-Token
# header. Leave UNSET (inert when empty) — the NIP-98 role system supersedes it.
# ADMIN_PASSWORD=
